# ---------------------------------------------------------------------------
# Pocket Nori — environment variable template
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Supabase (Database + Auth + Storage)
# Get from: https://supabase.com → Project → Settings → API
# ---------------------------------------------------------------------------

# Public Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to use in client-side; restricted by RLS
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — bypasses RLS entirely. Use ONLY for migrations and admin scripts.
# NEVER pass this key to application code or Celery workers.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# Anthropic (LLM extraction + brief generation)
# Get from: https://console.anthropic.com → API Keys
# Cost alert: set a $100/month alert on the Anthropic dashboard BEFORE use.
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Redis / Upstash (Celery broker + cache)
# Get from: https://console.upstash.com → Redis → Connect → rediss:// URL
# Format: rediss://:<password>@<host>:<port>
# Fallback option: Render Redis (~$7/month) if Upstash free tier is unreliable
# ---------------------------------------------------------------------------

UPSTASH_REDIS_URL=rediss://:your-password@your-host.upstash.io:6379

# ---------------------------------------------------------------------------
# Deepgram (transcription)
# Get from: https://console.deepgram.com → API Keys
# Pricing: ~$0.0043/min (Nova-3). One hour of meetings ≈ $0.26.
# ---------------------------------------------------------------------------

DEEPGRAM_API_KEY=your-deepgram-key

# ---------------------------------------------------------------------------
# Google OAuth (authentication + Calendar API)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: calendar.readonly, profile, email
# ---------------------------------------------------------------------------

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------------------
# Application settings
# ---------------------------------------------------------------------------

# Environment: development | staging | production
ENVIRONMENT=development

# FastAPI secret key — used for session signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-32-byte-hex-secret

# JWT algorithm
JWT_ALGORITHM=HS256

# Supabase JWT verification (API token auth)
# Defaults are usually correct for Supabase projects.
SUPABASE_JWT_AUDIENCE=authenticated
# Leave blank to auto-derive: ${SUPABASE_URL}/auth/v1
SUPABASE_JWT_ISSUER=
# Legacy projects that still issue HS256 tokens can set this.
SUPABASE_JWT_SECRET=
# JWKS cache TTL in seconds
SUPABASE_JWKS_TTL_SECONDS=3600

# Token expiry in minutes (default: 60 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API base URL (no trailing slash)
API_BASE_URL=http://localhost:8000

# Frontend URL (used in OAuth redirect URIs)
FRONTEND_URL=http://localhost:3000

# Frontend public API base URL (used by the Next.js app at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
